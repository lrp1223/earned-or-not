<!--pages/index/index.wxml-->
<view class="container">
  <view class="card user-card">
    <block wx:if="{{userInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text class="nickname">{{userInfo.nickName}}</text>
    </block>
    <block wx:else>
      <view class="avatar" style="background: #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 60px;">👤</view>
      <button class="btn-login" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">点击获取头像昵称</button>
    </block>
    <view class="total-net {{totalNet >= 0 ? 'amount-positive' : 'amount-negative'}}">
      年度盈亏：{{totalNetStr}} 元
    </view>
  </view>
  
  <view class="card">
    <view class="title">快速记账</view>
    <view class="quick-actions">
      <view class="action-item" bindtap="goRecord" data-type="lottery">
        <view class="action-icon lottery">🎰</view><text>彩票</text>
      </view>
      <view class="action-item" bindtap="goRecord" data-type="scratch">
        <view class="action-icon scratch">🎫</view><text>刮刮乐</text>
      </view>
      <view class="action-item" bindtap="goRecord" data-type="mahjong">
        <view class="action-icon mahjong">🀄</view><text>麻将</text>
      </view>
    </view>
  </view>
  
  <view class="card">
    <view class="title">最近记录</view>
    <view wx:if="{{recentRecords.length === 0}}" class="empty">暂无记录</view>
    <view wx:for="{{recentRecords}}" wx:key="_id" class="record-item">
      <view class="record-left">
        <text class="record-type">{{item.typeText}}</text>
        <text class="record-time">{{item.timeStr}}</text>
      </view>
      <view class="record-right">
        <text class="record-result {{item.net >= 0 ? 'win' : 'lose'}}">{{item.net >= 0 ? '赚了' : '亏了'}}</text>
        <text class="record-amount {{item.net >= 0 ? 'amount-positive' : 'amount-negative'}}">{{item.netStr}} 元</text>
      </view>
    </view>
  </view>
</view>
