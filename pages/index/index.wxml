<!--pages/index/index.wxml-->
<view class="container">
  <view class="card user-card">
    <block wx:if="{{avatarUrl}}">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" style="width: 140rpx; height: 140rpx; border-radius: 50%; margin-bottom: 20rpx; border: 4rpx solid #ff6b6b;"></image>
    </block>
    <block wx:else>
      <view class="avatar" style="background: linear-gradient(135deg, #ff6b6b, #ffd93d); display: flex; align-items: center; justify-content: center; font-size: 80rpx; color: white; width: 140rpx; height: 140rpx; border-radius: 50%; margin-bottom: 20rpx;">🎰</view>
    </block>
    <text class="nickname">{{nickname}}</text>
    <view class="total-net {{totalNet >= 0 ? 'amount-positive' : 'amount-negative'}}">
      年度盈亏：{{totalNetStr}} 元
    </view>
  </view>
  
  <view class="card">
    <view class="title">快速记账</view>
    <view class="quick-actions">
      <view class="action-item" bindtap="goRecord" data-type="lottery">
        <view class="action-icon lottery">🎰</view><text>彩票</text>
      </view>
      <view class="action-item" bindtap="goRecord" data-type="scratch">
        <view class="action-icon scratch">🎫</view><text>刮刮乐</text>
      </view>
      <view class="action-item" bindtap="goRecord" data-type="mahjong">
        <view class="action-icon mahjong">🀄</view><text>麻将</text>
      </view>
    </view>
  </view>
  
  <view class="card">
    <view class="title">最近记录 <text class="subtitle" bindtap="viewAll">查看全部 ›</text></view>
    <view wx:if="{{recentRecords.length === 0}}" class="empty">暂无记录</view>
    <view class="record-list" wx:else>
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="_id" bindtap="editRecord" data-id="{{item._id}}" data-type="{{item.type}}">
        <view class="record-icon {{item.type}}">{{item.type === 'lottery' ? '🎰' : item.type === 'scratch' ? '🎫' : '🀄'}}</view>
        <view class="record-info">
          <view class="record-top">
            <text class="record-type">{{item.typeText}}</text>
            <text class="record-amount {{item.net >= 0 ? 'amount-positive' : 'amount-negative'}}">{{item.netStr}}</text>
          </view>
          <view class="record-bottom">
            <text class="record-date">{{item.timeStr}}</text>
            <text class="record-result {{item.net >= 0 ? 'win' : 'lose'}}">{{item.net >= 0 ? '赚了' : '亏了'}}</text>
          </view>
        </view>
        <view class="record-arrow">›</view>
      </view>
    </view>
  </view>
</view>
