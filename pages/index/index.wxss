.user-card { display: flex; flex-direction: column; align-items: center; padding: 40rpx; }
.nickname { font-size: 32rpx; color: #333; margin-bottom: 20rpx; font-weight: bold; }
.total-net { font-size: 48rpx; font-weight: bold; }
.quick-actions { display: flex; justify-content: space-around; margin-top: 20rpx; }
.action-item { display: flex; flex-direction: column; align-items: center; padding: 20rpx; }
.action-icon { width: 100rpx; height: 100rpx; border-radius: 50rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; margin-bottom: 10rpx; }
.lottery { background: linear-gradient(135deg, #ff6b6b, #ff8e8e); }
.scratch { background: linear-gradient(135deg, #4ecdc4, #44a08d); }
.mahjong { background: linear-gradient(135deg, #f7b731, #e58e26); }

.title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.subtitle { font-size: 26rpx; color: #ff6b6b; }

.record-list { }
.record-item { display: flex; align-items: center; padding: 24rpx; background: #fafafa; border-radius: 16rpx; margin-bottom: 16rpx; }
.record-icon { width: 80rpx; height: 80rpx; border-radius: 40rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-right: 20rpx; flex-shrink: 0; }
.record-info { flex: 1; }
.record-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.record-type { font-size: 32rpx; font-weight: bold; color: #333; }
.record-amount { font-size: 36rpx; font-weight: bold; }
.record-bottom { display: flex; justify-content: space-between; align-items: center; }
.record-date { font-size: 24rpx; color: #999; }
.record-result { font-size: 26rpx; font-weight: bold; }
.record-result.win { color: #52c41a; }
.record-result.lose { color: #ff4d4f; }
.record-arrow { font-size: 40rpx; color: #ccc; margin-left: 16rpx; }

.empty { text-align: center; color: #999; padding: 40rpx; }

/* 自定义操作菜单 */
.action-menu-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.action-menu { position: fixed; left: 40rpx; right: 40rpx; bottom: 40rpx; background: white; border-radius: 24rpx; z-index: 101; overflow: hidden; }
.action-menu-title { text-align: center; padding: 30rpx; font-size: 28rpx; color: #999; border-bottom: 1rpx solid #f0f0f0; }
.action-menu-item { display: flex; align-items: center; justify-content: center; padding: 30rpx; font-size: 32rpx; color: #333; border-bottom: 1rpx solid #f0f0f0; }
.action-menu-item.delete { color: #ff4d4f; }
.action-menu-item:active { background: #f5f5f5; }
.action-icon { margin-right: 16rpx; font-size: 36rpx; }
.action-menu-cancel { text-align: center; padding: 30rpx; font-size: 32rpx; color: #666; background: #f5f5f5; margin-top: 16rpx; border-radius: 0 0 24rpx 24rpx; }
.action-menu-cancel:active { background: #e8e8e8; }
