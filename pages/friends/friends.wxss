/**pages/friends/friends.wxss**/
.search-card { padding: 20rpx; }
.search-box { display: flex; align-items: center; background: #f5f5f5; border-radius: 40rpx; padding: 0 20rpx; }
.search-input { flex: 1; height: 80rpx; padding: 0 20rpx; font-size: 30rpx; }
.search-btn { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }

.section-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }

.search-result { margin-bottom: 20rpx; }
.user-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.user-item:last-child { border-bottom: none; }
.user-info { display: flex; align-items: center; }
.user-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg, #ff6b6b, #ff8e8e); color: white; font-size: 32rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; }
.user-name { font-size: 30rpx; color: #333; }
.btn-add { background: #ff6b6b; color: white; border-radius: 30rpx; font-size: 26rpx; padding: 0 30rpx; }

.friend-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.friend-item:last-child { border-bottom: none; }
.friend-info { display: flex; align-items: center; flex: 1; }
.friend-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: linear-gradient(135deg, #4ecdc4, #44a08d); color: white; font-size: 36rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; }
.friend-detail { display: flex; flex-direction: column; }
.friend-name { font-size: 32rpx; color: #333; font-weight: 500; }
.friend-time { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.friend-stats { text-align: right; }
.stats-text { font-size: 28rpx; color: #666; }

.empty-tip { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }
