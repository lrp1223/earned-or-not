/**pages/profile/profile.wxss**/
.profile-card { padding: 40rpx; background: linear-gradient(135deg, #ff6b6b, #ff8e8e); border-radius: 24rpx; margin: 20rpx; }
.avatar-section { display: flex; flex-direction: column; align-items: center; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 50%; border: 6rpx solid white; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2); }
.avatar-default { background: linear-gradient(135deg, #ffd93d, #ff6b6b); display: flex; align-items: center; justify-content: center; font-size: 80rpx; }
.avatar-hint { margin-top: 16rpx; font-size: 24rpx; color: rgba(255,255,255,0.9); }

.info-section { margin-top: 30rpx; background: rgba(255,255,255,0.95); border-radius: 16rpx; padding: 20rpx; }
.info-item { display: flex; align-items: center; padding: 24rpx 20rpx; border-bottom: 1rpx solid #f0f0f0; }
.info-item:last-child { border-bottom: none; }
.info-item:active { background: #f5f5f5; border-radius: 12rpx; }
.label { flex: 1; font-size: 30rpx; color: #666; }
.value { font-size: 30rpx; color: #333; font-weight: 500; }
.id-text { font-size: 24rpx; color: #999; }
.arrow { margin-left: 20rpx; font-size: 36rpx; color: #ccc; }

.stats-card { padding: 40rpx; margin: 20rpx; background: white; border-radius: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 30rpx; display: flex; align-items: center; }
.section-title::before { content: "🏆"; margin-right: 12rpx; }

.stats-simple { display: flex; align-items: center; justify-content: space-around; padding: 20rpx 0; }
.stats-main { text-align: center; flex: 1; }
.stats-label { display: block; font-size: 28rpx; color: #999; margin-bottom: 12rpx; }
.stats-value { display: block; font-size: 48rpx; font-weight: bold; color: #333; }
.stats-value.positive { color: #52c41a; }
.stats-value.negative { color: #ff4d4f; }
.stats-divider { width: 2rpx; height: 80rpx; background: #f0f0f0; }

.about-card { padding: 40rpx; margin: 20rpx; background: white; border-radius: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }
.about-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; display: flex; align-items: center; }
.about-title::before { content: "ℹ️"; margin-right: 12rpx; }
.about-item { display: flex; align-items: center; padding: 20rpx 0; }
.about-label { width: 120rpx; font-size: 28rpx; color: #666; }
.about-value { font-size: 28rpx; color: #333; }
.about-dev { display: flex; align-items: center; flex: 1; }
.dev-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; margin-right: 12rpx; }
