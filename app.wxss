/**app.wxss**/
page { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f5f5f5; }
.container { padding: 20rpx; }
.card { background: white; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.btn-primary { background: linear-gradient(135deg, #ff6b6b, #ff8e8e); color: white; border-radius: 40rpx; font-size: 32rpx; font-weight: bold; }
.btn-primary::after { border: none; }
.title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }
.amount-positive { color: #52c41a; font-weight: bold; }
.amount-negative { color: #ff4d4f; font-weight: bold; }